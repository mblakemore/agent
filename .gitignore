# Claude Code
CLAUDE.md
.claude/
# Ignore everything under plan/ EXCEPT the CICD loop's tracked artifacts
# (plans, results, progress log). Use plan/* — not plan/ — so git can still
# descend into plan/CICD/ to honor the re-include below.
plan/*
!plan/CICD/

# Agent runtime state (.agent/ holds state/, history/, etc.)
.agent/
state/
agent_history/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# Test artifacts (pytest, coverage, mocking)
MagicMock/
.coverage
coverage.xml
htmlcov/
.pytest_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Local config overrides
config.local.json
.env
.env.*
*.local.*
